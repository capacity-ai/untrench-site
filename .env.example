# Analytics (client-side — prefix required by Next.js)
NEXT_PUBLIC_POSTHOG_PROJECT_KEY=

# Cloudflare Turnstile (site key is client-side, secret is server-only)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Slack webhook for contact form (deferred — graceful fallback if absent)
SLACK_WEBHOOK_URL=

# AI (future use)
ANTHROPIC_API_KEY=
